{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @staffd/agents build && pnpm --filter web build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/worker/scheduled",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/worker/vault",
      "schedule": "*/1 * * * *"
    },
    {
      "path": "/api/worker/morning-brief",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/worker/brief-push-dispatcher",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/worker/security-audit",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/worker/workflow-drain",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/worker/muapi-catalog-sync",
      "schedule": "0 * * * *"
    }
  ]
}
